MONGODB_URI=mongodb://localhost:27017
# Optional alias used in container/server environments.
MONGO_URI=mongodb://localhost:27017
MONGODB_DB=zuga
# Optional: override DNS resolvers used by Node for mongodb+srv lookups.
# Useful when querySrv ECONNREFUSED occurs on local networks.
MONGODB_DNS_SERVERS=1.1.1.1,8.8.8.8
BGG_API_KEY=change-me
ADMIN_MASTER_CODE=change-me
JWT_SECRET=change-me-please-use-a-long-random-secret
